{
  "name": "clean-node-framework",
  "version": "1.0.1",
  "author": "Igor Antonov",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --env-file=.env --watch --import tsx/esm src/main.ts",
    "start": "node --env-file=.env dist/main.js",
    "test": "TSX_TSCONFIG_PATH=tsconfig.test.json node --test --import tsx/esm test/unit/**/*.test.ts",
    "test:e2e": "TSX_TSCONFIG_PATH=tsconfig.test.json node --test --import tsx/esm test/e2e/**/*.test.ts"
  },
  "dependencies": {
    "formidable": "3.5.4",
    "inversify": "6.2.2",
    "pino": "9.14.0",
    "reflect-metadata": "0.2.2"
  },
  "devDependencies": {
    "@types/formidable": "3.5.1",
    "@types/node": "25.7.0",
    "@types/supertest": "6.0.3",
    "pino-pretty": "13.1.3",
    "supertest": "7.2.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
